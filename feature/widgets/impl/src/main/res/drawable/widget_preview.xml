<?xml version="1.0" encoding="utf-8"?>
<!--
  Static picker preview for pre-Android-15 (API < 35), where the system can't
  render the Glance `providePreview` composable. A representative dark feed
  card: a title bar over three author + text rows. On API 35+ the live
  `providePreview` (real sample posts) supersedes this.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="120dp"
    android:height="60dp"
    android:viewportWidth="240"
    android:viewportHeight="120">

    <!-- Card -->
    <path
        android:fillColor="#1B1C20"
        android:pathData="M14,0 H226 A14,14 0 0 1 240,14 V106 A14,14 0 0 1 226,120 H14 A14,14 0 0 1 0,106 V14 A14,14 0 0 1 14,0 Z" />

    <!-- Title -->
    <path android:fillColor="#C7C7CC" android:pathData="M16,14 H88 V25 H16 Z" />

    <!-- Row 1: author + text -->
    <path android:fillColor="#9A9AA0" android:pathData="M16,40 H74 V47 H16 Z" />
    <path android:fillColor="#67676D" android:pathData="M16,51 H204 V58 H16 Z" />

    <!-- Row 2 -->
    <path android:fillColor="#9A9AA0" android:pathData="M16,70 H66 V77 H16 Z" />
    <path android:fillColor="#67676D" android:pathData="M16,81 H188 V88 H16 Z" />

    <!-- Row 3 -->
    <path android:fillColor="#9A9AA0" android:pathData="M16,100 H80 V107 H16 Z" />
    <path android:fillColor="#67676D" android:pathData="M16,111 H160 V118 H16 Z" />
</vector>
