    <path android:fillColor="#FFFFFF" android:pathData="M20,36 a18,18 0 1,0 36,0 a18,18 0 1,0 -36,0 Z" />
    <path android:fillColor="#FFFFFF" android:pathData="M42,42 a14,14 0 1,0 28,0 a14,14 0 1,0 -28,0 Z" />
    <path android:fillColor="#FFFFFF" android:pathData="M21,46 H55 A7,7 0 0 1 55,60 H21 A7,7 0 0 1 21,46 Z" />
</vector>
