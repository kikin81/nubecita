<?xml version="1.0" encoding="utf-8"?>
<!-- Rounded dark card behind the static previewLayout (picker, API 31+). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#1B1C20" />
    <!-- Reuse the widget background radius (16dp; the system widget radius on
         API 31+ via values-v31) so the preview card matches the real widget. -->
    <corners android:radius="@dimen/widget_background_radius" />
</shape>
