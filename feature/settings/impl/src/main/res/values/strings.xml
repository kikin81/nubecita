<resources>
    <!-- Settings shell screen + sign-out flow -->
    <string name="settings_title">Settings</string>
    <string name="settings_back_content_description">Back</string>
    <!-- X-close affordance on the tablet/foldable Settings modal (replaces
         the phone-shape back-arrow when the screen renders as a centered
         modal sheet — at-or-above the Medium width breakpoint). -->
    <string name="settings_close_content_description">Close</string>
    <string name="settings_signout">Sign out</string>
    <string name="settings_signout_dialog_title">Sign out?</string>
    <string name="settings_signout_dialog_body">You\'ll need to sign in again to use Nubecita.</string>
    <string name="settings_signout_dialog_confirm">Sign out</string>
    <string name="settings_signout_dialog_cancel">Cancel</string>
    <string name="settings_signout_error">Couldn\'t sign out. Check your network and try again.</string>

    <!-- About-section version row. Label is plain "Version"; the version
         value (e.g. "1.104.0 (1104000)") rides in the row's
         supportingText slot below the label. _unknown is the fallback
         when PackageManager can't resolve the package — should never
         fire in practice. -->
    <string name="settings_version_row_label">Version</string>
    <string name="settings_version_unknown">unknown</string>

    <!-- About-section row linking to the developer's Bluesky profile. Tapping
         it pushes the developer's Profile route onto the MainShell back stack
         (NavigateToDeveloperProfile effect). -->
    <string name="settings_follow_developer_row_label">Follow the developer</string>

    <!-- Settings home identity header (Google Play-style sheet). Greeting
         receives the signed-in user's displayName; no_name variant fires
         when displayName is absent or blank. Manage-Account pill opens
         https://bsky.app/settings via the screen's LaunchUri effect. -->
    <string name="settings_header_greeting_with_name">Hi, %1$s!</string>
    <string name="settings_header_greeting_no_name">Hi!</string>
    <string name="settings_header_manage_account_cta">Manage your Bluesky account</string>
    <string name="settings_header_avatar_content_description">Profile photo</string>

    <!-- "Switch account" placeholder row (multi-account picker arrives in a
         later epic; v1 row is inert and fires a Coming-soon snackbar). -->
    <string name="settings_switch_account_label">Switch account</string>
    <string name="settings_switch_account_coming_soon">Multi-account — coming soon</string>
    <string name="settings_switch_account_avatar_content_description">Current account</string>

    <!-- Notifications section. v1 row deep-links into the OS app-
         notification-settings page (per-channel toggles, badge
         controls, importance overrides). In-app per-reason toggles
         live in the same section and arrive in a later epic. -->
    <string name="settings_notifications_row_label">Notifications</string>

    <!-- Nubecita Pro section (nubecita-q5ge.10). Two faces:
         - Non-Pro: an upsell row opening the paywall. "Support the
           developer" framing per the epic's honest-indie voice.
         - Pro: a current-plan info row + manage-subscription (Play
           deep link) + restore-purchases rows.
         The current-plan caption is composed from the resolved plan
         period + store-localized price; _active is the neutral fallback
         when the price/period couldn't be resolved. -->
    <string name="settings_pro_section_label">Nubecita Pro</string>
    <string name="settings_pro_upsell_label">Nubecita Pro</string>
    <string name="settings_pro_upsell_supporting">Support the developer and unlock Pro perks</string>
    <string name="settings_pro_member_label">Nubecita Pro</string>
    <string name="settings_pro_current_plan_active">Active</string>
    <!-- %1$s is the store-localized price string, e.g. "$19.99". -->
    <string name="settings_pro_current_plan_annual">Annual · %1$s/yr</string>
    <string name="settings_pro_current_plan_monthly">Monthly · %1$s/mo</string>
    <string name="settings_pro_manage_label">Manage subscription</string>
    <string name="settings_pro_restore_label">Restore purchases</string>
