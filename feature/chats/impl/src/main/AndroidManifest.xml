<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <!-- Inline Direct Reply target for DM notifications (nubecita-1fy.17).
             Manifest-declared (not runtime-registered) so it works even when the
             app process was killed between posting the notification and replying.
             Not exported: only the app's own notification PendingIntent triggers it. -->
        <receiver
            android:name=".worker.DmReplyReceiver"
            android:exported="false" />

        <!-- Debug-only trigger for background polls (nubecita-1fy.15).
             Exported so it can be fired via `adb shell am broadcast`. -->
        <receiver
            android:name=".worker.DmPollDebugReceiver"
            android:exported="true" />
    </application>
</manifest>
