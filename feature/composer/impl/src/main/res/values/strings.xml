<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Top-bar actions -->
    <string name="composer_close_action">Close composer</string>
    <string name="composer_post_action">Post</string>

    <!-- Attachment-row actions -->
    <string name="composer_add_image_action">Add image</string>
    <string name="composer_remove_attachment_action">Remove attachment</string>

    <!-- Text input affordances -->
    <string name="composer_text_field_placeholder">What\'s on your mind?</string>
    <string name="composer_text_field_label">Compose post</string>

    <!-- Character counter (a11y). The over-limit form uses a positive
         integer for the offset; "by 1" vs "by 2" doesn't change English
         grammar so a quantity-aware plural would be redundant for the
         languages we currently support, but keeping it as a `plurals`
         entry would be the right move when localization expands. -->
    <plurals name="composer_chars_remaining">
        <item quantity="one">%1$d character remaining</item>
        <item quantity="other">%1$d characters remaining</item>
    </plurals>
    <string name="composer_chars_over_limit">Over the 300 character limit by %1$d</string>

    <!-- Submission progress (a11y) -->
    <string name="composer_submitting">Submitting your post</string>

    <!-- Errors (snackbar, single-line — V1 collapses every typed
         ComposerError to one of these strings; richer error UX is a
         follow-up). -->
    <string name="composer_error_generic">Couldn\'t post. Try again.</string>
    <string name="composer_error_network">No connection. Check your network and try again.</string>
    <string name="composer_error_unauthorized">Your session expired. Sign in again to post.</string>
    <!--
        `%1$d` here is an ORDINAL ("Image #1", "Image #2"), not a
        QUANTITY — every value renders with the same English grammar.
        Lint's PluralsCandidate heuristic flags it because of the
        adjacent word; suppress for this string only.
    -->
    <string name="composer_error_upload_failed" tools:ignore="PluralsCandidate">Image %1$d failed to upload.</string>
    <string name="composer_error_parent_not_found">This post is no longer available.</string>
    <!-- Shown when the reply target's author has limited who can reply and this
         viewer isn't allowed (threadgate changed after they tapped reply). -->
    <string name="composer_error_reply_not_allowed">You can\'t reply to this post.</string>
    <!-- Shown when the quote target's author has limited who can quote it and this
         viewer isn't allowed (postgate changed after they chose to quote). -->
    <string name="composer_error_quote_not_allowed">You can\'t quote this post.</string>

    <!-- Typeahead empty-state row (shown inside the @-mention suggestion
         card when the lookup ran but matched zero actors). `%1$s` is the
         active token without the leading @. Distinct from the failure
         path, which collapses to a hidden card. -->
    <string name="composer_typeahead_no_matches">No matches for @%1$s</string>

    <!-- Reply-mode parent-fetch failure tile. Tap-to-retry text
         shown when getPostThread for the reply target failed. -->
    <string name="composer_reply_parent_load_failed_retry">Couldn\'t load reply target. Tap to retry.</string>

    <!-- a11y onClickLabel for the parent-fetch retry tile.
         TalkBack announces this verb as the action when the tile
         is focused. -->
    <string name="composer_reply_parent_retry_action_label">Retry</string>

    <!-- a11y contentDescription for the reply-parent context card. The visual
         card shows the post like a full post (no caption); this gives screen
         readers the "what is this card" context. `%1$s` is the author display
         name (or handle). -->
    <string name="composer_reply_header">Replying to %1$s</string>

    <!-- a11y contentDescription for the quoted-post context card (visual card has
         no caption). `%1$s` is the author display name (or handle). -->
    <string name="composer_quote_header">Quoting %1$s</string>

    <!-- Quote-mode quote-fetch failure tile. Tap-to-retry text shown
         when getPosts for the quote target failed. -->
    <string name="composer_quote_load_failed_retry">Couldn\'t load quoted post. Tap to retry.</string>

    <!-- a11y contentDescription for the dismiss (X) button on the
         quote card; tapping it detaches the quoted post. -->
    <string name="composer_quote_remove_action_label">Remove quoted post</string>

    <!-- Discard-confirmation dialog. Shown when the user attempts to
         leave the composer (back-press or toolbar X) while the draft
         has content. -->
    <string name="composer_discard_title">Discard draft?</string>
    <string name="composer_discard_cancel">Cancel</string>
    <string name="composer_discard_confirm">Discard</string>

    <!-- Language picker — search field label, a11y description, and
         confirm/dismiss footer affordances. -->
    <string name="composer_language_search_label">Search</string>
    <string name="composer_language_search_content_description">Search languages</string>
    <string name="composer_language_picker_done">Done</string>
    <string name="composer_language_picker_cancel">Cancel</string>

    <!-- Audience picker — who can reply / quote a new post, plus the
         save-as-default and reset affordances and the confirm/dismiss footer. -->
    <string name="composer_audience_title">Who can interact?</string>
    <string name="composer_audience_reply_section">Who can reply</string>
    <string name="composer_audience_anyone">Anyone</string>
    <string name="composer_audience_nobody">Nobody</string>
    <string name="composer_audience_followers">Your followers</string>
    <string name="composer_audience_following">People you follow</string>
    <string name="composer_audience_mentioned">People you mention</string>
    <string name="composer_audience_lists">Select from your lists</string>
    <string name="composer_audience_allow_quotes">Allow quote posts</string>
    <string name="composer_audience_save_default">Save these options for next time</string>
    <string name="composer_audience_reset">Reset</string>
    <string name="composer_audience_picker_done">Done</string>
    <string name="composer_audience_picker_cancel">Cancel</string>

    <!-- Audience chip — the composer-options-row tap target that opens the
         picker. Shows "Visible to all" for the wide-open default, else
         "Interaction limited". Save-error is a non-blocking snackbar shown when
         persisting the chosen audience as the account default fails. -->
    <string name="composer_audience_chip_default">Visible to all</string>
    <string name="composer_audience_chip_limited">Interaction limited</string>
    <string name="composer_audience_save_error">Couldn\'t save as default. It still applies to this post.</string>

    <!-- Language chip — shown on the empty-selection ("explicit no
         language") state. Distinct from the null-selection state,
         which renders the device-locale display name to mirror what
         the repo's wtq.12 device-locale fallback would send. -->
    <string name="composer_language_chip_none">No language</string>
</resources>
