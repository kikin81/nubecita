<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Brand-mark accessibility label announced by TalkBack when the
         NubecitaLogomark composable is the sole content of a focusable
         container. -->
    <string name="logomark_content_description">Nubecita</string>

    <!-- PostCard author + repost-attribution lines.
         postcard_handle and postcard_relative_time are rendered as separate
         Text composables in AuthorLine so the handle can truncate with
         ellipsis (long bsky handles are common) without dragging the
         right-pinned timestamp onto a second visual line. -->
    <string name="postcard_reposted_by">%1$s reposted</string>
    <string name="postcard_handle">\@%1$s</string>
    <string name="postcard_relative_time">%1$s</string>

    <!-- PostCard unsupported-embed chip + friendly type labels.
         Format: "Unsupported embed: <type>" where <type> is the matching
         postcard_embed_label_* string. New embed types unlock by adding
         a new label here AND extending the when() in unsupportedEmbedLabel(). -->
    <string name="postcard_unsupported_embed_format">Unsupported embed: %1$s</string>
    <string name="postcard_embed_label_external">link card</string>
    <string name="postcard_embed_label_record">quoted post</string>
    <string name="postcard_embed_label_video">video</string>
    <string name="postcard_embed_label_record_with_media">quoted post with media</string>
    <string name="postcard_embed_label_unknown">embed</string>

    <!-- PostCard quoted-post chips. quoted_post_unavailable is the single
         piece of copy rendered for every RecordUnavailable.Reason
         (NotFound/Blocked/Detached/Unknown) per the YAGNI design.
         quoted_post_view_thread is the recursion-bound chip rendered
         when a quoted post itself quotes another post (one-level bound). -->
    <string name="postcard_quoted_post_unavailable">Quoted post unavailable</string>
    <string name="postcard_quoted_post_view_thread">View thread</string>

    <!-- PostCard action-row accessibility labels. Reply / share are
         one-shot actions: passed as clickable's onClickLabel so TalkBack
         announces "Double-tap to <verb>". Like / repost are toggles:
         passed as the Icon's contentDescription, with PostStat using
         Modifier.toggleable + Role.Switch so TalkBack announces the
         on/off state alongside the noun ("Like, switch, on, double tap
         to toggle"). -->
    <string name="postcard_action_reply">Reply</string>
    <string name="postcard_action_repost">Repost</string>
    <string name="postcard_action_like">Like</string>
    <string name="postcard_action_share">Share post</string>
    <!-- Long-press on the share button copies the post permalink. Surfaced
         to TalkBack via combinedClickable's onLongClickLabel so the
         long-press action gets a meaningful announcement. -->
    <string name="postcard_action_copy_link">Copy link to post</string>

    <!-- ThreadFold copy. thread_fold_view_full_thread is both the visible
         label and the clickable's onClickLabel so TalkBack announces
         "View full thread, button, double-tap to View full thread".
         thread_fold_more_count is a quantity string for the optional
         "· N more" elision indicator (English doesn't differ between
         one and other; resource enables proper localization elsewhere). -->
    <string name="thread_fold_view_full_thread">View full thread</string>
    <plurals name="thread_fold_more_count">
        <item quantity="one">· %1$d more</item>
        <item quantity="other">· %1$d more</item>
    </plurals>

    <!-- VideoPosterEmbed fallback content description when the lexicon's
         `altText` field is null. TalkBack would otherwise announce the
         clickable Box with Role.Button but no label ("button, double-tap
         to activate"), which is meaningless. -->
    <string name="video_poster_default_content_description">Play video</string>

    <!-- ListDetailSceneStrategy detail-pane empty state. Used by any feature
         whose entry carries `listPane(detailPlaceholder = { PostDetailPaneEmptyState() })`.
         Bead F (nubecita-s6p.6) promoted this from :feature:feed:impl when
         Profile became the second caller. -->
    <string name="nubecita_detail_pane_select_post">Select a post to read</string>
</resources>
