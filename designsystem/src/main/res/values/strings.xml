<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Brand-mark accessibility label announced by TalkBack when the
         NubecitaLogomark composable is the sole content of a focusable
         container. -->
    <string name="logomark_content_description">Nubecita</string>

    <!-- Nubecita Pro "Supporter" badge shown on a Pro user's own profile
         hero. Deliberately neutral wording — a patron/supporter marker,
         NOT an identity-verification ("verified") signal. The label text
         doubles as the badge's TalkBack announcement. -->
    <string name="supporter_badge_label">Supporter</string>

    <!-- PostCard author + repost-attribution lines.
         postcard_handle and postcard_relative_time are rendered as separate
         Text composables in AuthorLine so the handle can truncate with
         ellipsis (long bsky handles are common) without dragging the
         right-pinned timestamp onto a second visual line. -->
    <string name="postcard_reposted_by">%1$s reposted</string>
    <string name="postcard_handle">\@%1$s</string>
    <string name="postcard_relative_time">%1$s</string>

    <!-- PostCard unsupported-embed chip + friendly type labels.
         Format: "Unsupported embed: <type>" where <type> is the matching
         postcard_embed_label_* string. New embed types unlock by adding
         a new label here AND extending the when() in unsupportedEmbedLabel(). -->
    <string name="postcard_unsupported_embed_format">Unsupported embed: %1$s</string>
    <string name="postcard_embed_label_external">link card</string>
    <string name="postcard_embed_label_record">quoted post</string>
    <string name="postcard_embed_label_video">video</string>
    <string name="postcard_embed_label_record_with_media">quoted post with media</string>
    <string name="postcard_embed_label_unknown">embed</string>

    <!-- PostCard quoted-post chips. quoted_post_unavailable is the single
         piece of copy rendered for every RecordUnavailable.Reason
         (NotFound/Blocked/Detached/Unknown) per the YAGNI design.
         quoted_post_view_thread is the recursion-bound chip rendered
         when a quoted post itself quotes another post (one-level bound). -->
    <string name="postcard_quoted_post_unavailable">Quoted post unavailable</string>
    <string name="postcard_quoted_post_view_thread">View thread</string>

    <!-- PostCard action-row accessibility labels. Reply / share are
         one-shot actions: passed as clickable's onClickLabel so TalkBack
         announces "Double-tap to <verb>". Like / repost are toggles:
         passed as the Icon's contentDescription, with PostStat using
         Modifier.toggleable + Role.Switch so TalkBack announces the
         on/off state alongside the noun ("Like, switch, on, double tap
         to toggle"). -->
    <string name="postcard_action_reply">Reply</string>
    <!-- Content description for the reply action when the post's author has
         restricted who can reply (threadgate) and this viewer is not allowed. -->
    <string name="postcard_action_reply_disabled">Replies are limited</string>
    <string name="postcard_action_repost">Repost</string>
    <!-- Accessibility label for the repost cell when a tap opens the
         Repost/Quote menu (it's an "options" button, not a direct toggle). -->
    <string name="postcard_action_repost_options">Repost options</string>
    <!-- Repost menu item / long-press label shown when the viewer has already
         reposted: tapping undoes the repost. -->
    <string name="postcard_action_undo_repost">Undo repost</string>
    <!-- Repost menu item: open the composer to quote this post. -->
    <string name="postcard_action_quote">Quote post</string>
    <string name="postcard_action_like">Like</string>
    <string name="postcard_action_bookmark">Bookmark</string>
    <string name="postcard_action_share">Share post</string>
    <!-- Long-press on the share button copies the post permalink. Surfaced
         to TalkBack via combinedClickable's onLongClickLabel so the
         long-press action gets a meaningful announcement. -->
    <string name="postcard_action_copy_link">Copy link to post</string>

    <!-- PostCard 5th action-row affordance: the overflow icon's
         accessibilityLabel. TalkBack announces "More options, button,
         double-tap to activate". Matches the established
         "More options" copy used by ProfileHero's overflow. -->
    <string name="postcard_action_more">More options</string>

    <!-- PostCard overflow-menu entries. Mute / Unmute / Block / Unblock
         carry the author @handle interpolated via the positional %1$s
         arg. The actual RPC writes ship under oftc.3 (Report), oftc.4
         (Block/Unblock), and oftc.5 (Mute/Unmute/MuteThread). oftc.2 wires
         the labels and surfaces a coming-soon snackbar on tap. -->
    <string name="moderation_action_report_post">Report post</string>
    <string name="moderation_action_mute_author">Mute \@%1$s</string>
    <string name="moderation_action_unmute_author">Unmute \@%1$s</string>
    <string name="moderation_action_block_author">Block \@%1$s</string>
    <string name="moderation_action_unblock_author">Unblock \@%1$s</string>
    <string name="moderation_action_mute_thread">Mute thread</string>
    <string name="moderation_action_unmute_thread">Unmute thread</string>
    <string name="moderation_action_copy_post_text">Copy post text</string>

    <!-- Tombstone copy for blocked / not-found / detached posts rendered in
         place of a normal PostCard. tombstone_blocked_post + tombstone_unblock
         are paired strings ("Post from a blocked user" + "Unblock" CTA); only
         the unblock affordance dispatches an RPC (route through the same
         oftc.4 unblock flow). tombstone_not_found_post is a plain notice with
         no affordance — the post is gone, there's no recovery action. -->
    <string name="tombstone_blocked_post">Post from a blocked user</string>
    <string name="tombstone_unblock">Unblock</string>
    <string name="tombstone_not_found_post">Post unavailable</string>

    <!-- ThreadFold copy. thread_fold_view_full_thread is both the visible
         label and the clickable's onClickLabel so TalkBack announces
         "View full thread, button, double-tap to View full thread".
         thread_fold_more_count is a quantity string for the optional
         "· N more" elision indicator (English doesn't differ between
         one and other; resource enables proper localization elsewhere). -->
    <string name="thread_fold_view_full_thread">View full thread</string>
    <plurals name="thread_fold_more_count">
        <item quantity="one">· %1$d more</item>
        <item quantity="other">· %1$d more</item>
    </plurals>

    <!-- VideoPosterEmbed fallback content description when the lexicon's
         `altText` field is null. TalkBack would otherwise announce the
         clickable Box with Role.Button but no label ("button, double-tap
         to activate"), which is meaningless. -->
    <string name="video_poster_default_content_description">Play video</string>

    <!-- ListDetailSceneStrategy detail-pane empty states. Used by any feature
         whose entry carries `listPane(detailPlaceholder = { DetailPaneEmptyState(icon, message) })`.
         Post-list surfaces (Feed, Profile, Search) use _select_post; Chats uses
         _select_conversation. -->
    <string name="nubecita_detail_pane_select_post">Select a post to read</string>
    <string name="nubecita_detail_pane_select_conversation">Select a conversation</string>

    <!-- MediaContentWarningCover — the scrim shown over sensitive (NSFW-labelled)
         media until the viewer taps "Show anyway". media_warning_sensitive is the
         header; the category line names which label triggered it; media_warning_show
         is the reveal CTA (hidden when the hide is non-overridable, i.e. the forced
         adult-gate-off case). -->
    <string name="media_warning_sensitive">Sensitive content</string>
    <string name="media_warning_show">Show anyway</string>
    <string name="media_warning_cat_adult">Adult Content</string>
    <string name="media_warning_cat_suggestive">Sexually Suggestive</string>
    <string name="media_warning_cat_graphic">Graphic Media</string>
    <string name="media_warning_cat_nudity">Non-sexual Nudity</string>
    <string name="verification_badge_verified_description">Verified account</string>
    <string name="verification_badge_trusted_verifier_description">Trusted verifier</string>
</resources>
