<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Required on Android 13+ (API 33+) to post notifications. The runtime
        permission prompt is fired by :feature:login:impl after a successful
        login (the natural first-benefit moment) — see :core:push's design.md
        "POST_NOTIFICATIONS prompt fires after first successful login" decision.
        Pre-API-33 installs receive notifications without any prompt.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".NubecitaApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/auth_data_extraction_rules"
        android:fullBackupContent="@xml/auth_backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nubecita">
        <!--
            Disable Firebase Messaging auto-init at process load. We re-enable
            it explicitly from NubecitaApplication.onCreate so that:

            (1) Production: the explicit enable runs every cold start, same
                net behavior as the default auto-init would have given us.

            (2) Tests: HiltTestApplication runs instead of NubecitaApplication,
                so the explicit enable never fires. FCM never tries to start
                NubecitaFcmService, which is critical because the service is
                @AndroidEntryPoint and HiltTestApplication doesn't have the
                SERVICE Hilt component wired up — without this guard, every
                instrumented test that runs in this APK's process crashes
                inside Hilt_NubecitaFcmService.onCreate with "The component
                was not created" the moment Firebase pings the service.

            The service-level instrumented tests (deferred to nubecita-ac39)
            will wire their own Hilt SERVICE-component test plumbing and
            opt back into auto-init via their own setup.
        -->
        <meta-data
            android:name="firebase_messaging_auto_init_enabled"
            android:value="false" />
        <!--
            Disable WorkManager's default androidx.startup initializer so the
            Hilt-aware Configuration.Provider on NubecitaApplication is used
            instead (on-demand init via Configuration.Provider). Required for
            @HiltWorker dependency injection on the background DM-poll worker
            (nubecita-1fy.15). The provider node is merged-into (not replaced);
            only the WorkManagerInitializer meta-data is removed.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
        <!--
            Disable Firebase's automatic Activity-based screen_view reporting.
            It is Activity/Fragment-based and cannot see our single-Activity
            Jetpack Navigation 3 / Compose destinations, so it would only ever
            report "MainActivity". We emit screen_view manually from the
            NavDisplay host layer instead (see TrackScreenViews +
            NavKey.toAnalyticsScreenOrNull, nubecita-049f.2), mapping each top
            NavKey to a stable, PII-free AnalyticsScreen route name.
        -->
        <meta-data
            android:name="google_analytics_automatic_screen_reporting_enabled"
            android:value="false" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:supportsPictureInPicture="true"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation|keyboardHidden">
            <!--
                supportsPictureInPicture enables the Pro PiP perk; configChanges is
                LOAD-BEARING (design D7): entering/leaving PiP is a configuration
                change, and without these flags Android would recreate MainActivity,
                tearing down the Nav3 back stack mid-transition. The set covers the
                PiP transition plus rotation. Keep singleTask (OAuth redirect routing)
                and adjustResize (IME inset handling).
            -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                Inbound share target: receive shared text/links (text/plain) and a
                single image (image/*) via ACTION_SEND into the composer. This
                widens the already-exported MainActivity's launchable surface, so
                MainActivity.handleShareIntent treats the payload as untrusted:
                text is validated via ShareIntentParser, and the image content://
                is byte-verified and copied into app-private storage by
                SharedMediaStore before a ComposerRoute is published.
            -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
                <data android:mimeType="image/*" />
            </intent-filter>
            <!--
                Verified Android App Link for the OAuth redirect.
                android:autoVerify="true" tells the package manager to fetch
                https://nubecita.app/.well-known/assetlinks.json on install / update
                and pin this app as the verified handler when the signing-cert
                fingerprint matches one listed there. Verified handlers bypass the
                chooser dialog entirely, so the Chrome Custom Tab → app redirect is
                seamless. Without autoVerify the OS would show a chooser between
                Nubecita and the browser, defeating the migration.

                pathPrefix (not exact path) so additional redirect_uris on the same
                host can be added without a manifest change. MainActivity.handleIntent
                re-validates the exact path before forwarding to the broker, so
                the looser filter doesn't widen the attack surface.

                Scheme + host derive from the OAuth client_id host (nubecita.app),
                per AT Protocol's Discoverable Client rule.
            -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="nubecita.app"
                    android:pathPrefix="/oauth-redirect" />
            </intent-filter>
            <!--
                Legacy OAuth redirect — Bluesky's authorization server sends the user
                back via app.nubecita:/oauth-redirect after PAR.
                android:launchMode="singleTask" ensures the redirect re-delivers to
                this MainActivity instance via onNewIntent rather than spawning a new
                task; MainActivity.handleIntent forwards the URI to OAuthRedirectBroker
                for LoginViewModel to consume.

                Scheme MUST be the FQDN of client_id reversed, per AT Protocol's
                Discoverable Client rule (nubecita.app → app.nubecita). It does
                NOT match the app's applicationId (net.kikin.nubecita). The auth server
                rejects mismatches with HTTP 400 invalid_redirect_uri.

                KEPT ALONGSIDE the HTTPS App Link filter above during the migration to
                a verified Android App Link. The hosted client-metadata.json drives
                which redirect_uri the authorization server picks at PAR time; until
                that file is migrated to the HTTPS value AND the change has soaked long
                enough for the long tail of installs to update, this is still the
                canonical callback target. Removing it prematurely breaks OAuth for
                every install whose cached metadata still names the custom scheme.
                Removal is a separately tracked, post-rollout chore — do NOT delete
                without confirming production install distribution.
            -->
            <!--
                AppLinkUrlError suppressed: lint expects an android:host whenever
                android:path is present (App Link convention for https:// URIs).
                This is a custom-scheme deep link per RFC 8252 — the redirect URI
                is "app.nubecita:/oauth-redirect" with a single slash and no
                host component, exactly as registered in client-metadata.json.
                Adding a placeholder host would change the URI shape and break
                Bluesky's authorization-server matching.
            -->
            <intent-filter tools:ignore="AppLinkUrlError">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="app.nubecita"
                    android:path="/oauth-redirect" />
            </intent-filter>
            <!--
                Verified Android App Link for our OWN profile deep-link
                surface. We control nubecita.app and its assetlinks.json
                already lists the app's signing-cert fingerprints (verified
                by the OAuth-redirect filter above which has been live for
                some time). The OS treats nubecita.app as a verified handler
                for this app, so https://nubecita.app/profile/... URLs
                bypass the chooser dialog and open Nubecita directly.

                Used today by surfaces WE control — push notifications,
                email links, future share sheet upgrades. The Bluesky-shaped
                bsky.app filter below remains the chooser fallback for URLs
                shared into Nubecita from anywhere else.

                pathPrefix="/profile/" (with trailing slash — narrow enough
                to exclude `/profiles`, `/profile-deprecated`, etc) keeps the
                verified scope tight and covers kf6k.3's /post suffix too.
                handleIntent's matcher set discriminates path shapes
                in-process. Same pattern as bsky.app's filter.

                Web fallback: a non-installed user clicking the URL in a
                browser hits nubecita.app, which 302s to the equivalent
                bsky.app URL — tracked separately (see kf6k.2 PR body).
            -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="nubecita.app"
                    android:pathPrefix="/profile/" />
                <data
                    android:scheme="https"
                    android:host="nubecita.app"
                    android:pathPrefix="/group/join/" />
            </intent-filter>
            <!--
                bsky.app deep-link entry. Tapping a /profile/{handle} or
                /profile/{handle}/post/{rkey} URL from any app on the device
                surfaces Nubecita as an "Open with" chooser candidate.

                NOT autoVerified: we don't control bsky.app's assetlinks.json,
                so verified-handler status isn't available — declaring
                android:autoVerify="true" would silently fail verification and
                degrade to chooser anyway, so we omit the attribute (default
                false). We register as a chooser candidate, never the default
                handler. (kf6k.5 §"Manifest").

                Single intent-filter block with android:pathPrefix="/profile/"
                covers both the profile (kf6k.2) and the /profile/{h}/post/{r}
                (kf6k.3) shapes. handleIntent's matcher set disambiguates the
                two — keeping the filter coarse avoids chooser pollution from
                per-shape filter splits.

                Belt-and-suspenders defenses live downstream:
                - IntentActionFilter on each NavKeyDeepLinkMatcher rejects
                  non-VIEW actions at the matcher boundary.
                - isValidActor (and the future kf6k.3 rkey validator) reject
                  malformed placeholders before any XRPC call.
                - Unmatched URIs fall through to the Timber.d log in
                  MainActivity.handleIntent; no destructive side effects.
            -->
            <!--
                autoVerify="false": bsky.app is a third-party domain we don't
                own, so Android App Links verification (assetlinks.json at the
                domain's .well-known) can never pass. This is a deliberate
                (chooser-offered) deep link, NOT a verified App Link — declaring
                it explicitly silences AppLinkWarning and documents intent. Our
                own verified App Link work (the OAuth redirect) is separate
                (nubecita-o4rv).
            -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="bsky.app"
                    android:pathPrefix="/profile/" />
            </intent-filter>
            <!--
                Custom-scheme counterpart to the bsky.app filter above.
                Useful for push notifications, widgets, and a future share
                extension that can construct an unambiguous nubecita://
                target without depending on bsky.app's link ownership.

                Constrained to host="profile" so the OS only routes
                nubecita://profile/... URIs to MainActivity — a bare
                `<data android:scheme="nubecita" />` would also match
                nubecita://settings, nubecita://anything-else and surface
                the app for arbitrary URIs that no matcher claims. Path
                discrimination (nubecita://profile/{handle} vs
                nubecita://profile/{handle}/post/{rkey}) stays in-process
                via the matcher set. Future surfaces (e.g. a hypothetical
                nubecita://compose) get their own scheme+host filters.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="nubecita"
                    android:host="profile" />
            </intent-filter>
            <!--
                Background DM-notification tap target (nubecita-1fy.15). The
                local notification's PendingIntent fires a package-constrained
                VIEW intent at nubecita://chat/{otherUserDid}; this filter routes
                it to MainActivity, where ChatDeepLinkModule's matcher resolves
                it to the Chat NavKey. host="chat" is constrained so only chat
                URIs route here. Custom-scheme only — no autoVerify (we never
                receive these from the web).
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="nubecita"
                    android:host="chat" />
            </intent-filter>
        </activity>
        <!--
            FCM messaging service is registered from `:core:push`'s own
            AndroidManifest.xml so the manifest entry stays co-located with
            the implementation class and `:core:push`'s lint sees it (the
            class isn't on `:app`'s compile classpath because the dep is
            declared `implementation`, not `api`).
        -->
    </application>

</manifest>
