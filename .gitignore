# Gradle
.gradle/
build/

# Release build artifacts (used as the local AAB drop dir for
# `bundleRelease` smoke tests and Firebase App Distribution uploads —
# the AAB is a 22MB+ binary that should never be committed).
app/release/

# IDE
.idea/
*.iml
.vscode/
.kotlin/
# IntelliJ/Eclipse output dir for Kotlin/Java modules. Gradle uses
# `build/` (already ignored); `bin/` is emitted by the IDE's own
# compile-on-save path — load-bearing for the IDE, never for git.
**/bin/

# Local environment
local.properties
*.keystore
keystore.properties

# Firebase service-account credentials (NEVER commit; loaded from
# FIREBASE_SERVICE_ACCOUNT GitHub secret in release.yaml). Note:
# app/google-services.json IS committed — it's package + SHA-1 scoped and
# safe in a public repo.
firebase-sa-*.json
firebase-service-account*.json
google-application-credentials*.json

# OS
.DS_Store
Thumbs.db

# Node (for commitlint/commitizen)
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log

# Python (for scripts/ venv if used)
__pycache__/
*.pyc
.venv/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Claude Code: share skills + slash commands, ignore local settings/logs.
# (Overrides a global .claude/ ignore that would otherwise hide everything.)
!.claude/
.claude/*
!.claude/skills/
!.claude/skills/**
!.claude/commands/
!.claude/commands/**

# Cached upstream variable font for scripts/update_material_symbols.sh.
# The 14.9 MB font lives here; only the ~50 KB subset under
# designsystem/src/main/res/font/ is checked in.
build/icon-cache/

# Superpowers brainstorm session artifacts (mockup HTML + server state).
# Regenerated per session; never committed.
.superpowers/

# Fastlane / Bundler. Gemfile + Gemfile.lock + fastlane/{Fastfile,Appfile,
# Pluginfile,README.md} ARE committed; everything below is local-only.
vendor/bundle/
.bundle/
fastlane/report.xml
fastlane/test_output/

# Marketing screenshots: commit ONLY the final framed images, as JPG
# (*_framed.jpg) — small enough for the repo and accepted by Play. Raw PNG
# captures and frameit's intermediate *_framed.png are reproducible from
# `bundle exec fastlane screenshots` / `screenshots_tablet`, so ignore every
# PNG in the screenshot dirs plus the HTML overview.
fastlane/metadata/android/*/images/*Screenshots/*.png
fastlane/metadata/android/screenshots.html

# app-health skill: local health reports contain real user metrics — never commit (public repo)
health-reports/

# Local reference material (third-party article digests) — never commit (public
# repo, copyright); committed specs cite source URLs. See docs/references/README.md.
docs/references/
