package_name("net.kikin.nubecita")

# Intentionally NOT setting `json_key_file` here.
#
# fastlane's `supply` action requires a `service_account`-type JSON when
# `json_key_file` is set — it does NOT recognize WIF (`external_account`,
# from `google-github-actions/auth@v2`) or local impersonation
# (`impersonated_service_account`, from
# `gcloud auth application-default login --impersonate-service-account=...`)
# credential JSONs, and fails with
# "Invalid Google Credentials file provided - no credential type found."
#
# Leaving `json_key_file` unset routes supply through
# `Google::Auth.get_application_default`, which handles every credential
# type the gcloud + workload-identity toolchain produces and reads
# `GOOGLE_APPLICATION_CREDENTIALS` automatically. See fastlane/README.md
# for the local + CI auth flows.
