package_name("net.kikin.nubecita")

# Intentionally no `json_key_file` here while we diagnose WIF auth.
# Supply auto-reads `GOOGLE_APPLICATION_CREDENTIALS` into that param,
# but the explicit `json_key_file` path only accepts `service_account`
# JSON. WIF (`external_account`) creds have to route through supply's
# ADC fallback — which is what the diagnostic workflow at
# `.github/workflows/wif-auth-diagnostic.yaml` is meant to validate.
# See fastlane/README.md for the auth picture.
