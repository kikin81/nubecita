package_name("net.kikin.nubecita")

# Intentionally no `json_key_file`. Supply auto-reads
# `GOOGLE_APPLICATION_CREDENTIALS` into that param, but the explicit
# `json_key_file` path only accepts `service_account` JSON. WIF
# (`external_account`) creds have to route through supply's ADC fallback,
# which the Fastfile pre-flight prepares by stripping the env var when it
# points at a non-SA type. See fastlane/README.md.
