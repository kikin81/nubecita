package_name("net.kikin.nubecita")

# Intentionally no `json_key_file` here. With `:json_key` unset, supply
# falls through to `Google::Auth.get_application_default`, which reads
# `GOOGLE_APPLICATION_CREDENTIALS` (or the gcloud well-known path) and
# handles `service_account`, `authorized_user`, and `external_account`
# (WIF) JSONs via the bundled `googleauth` gem. See fastlane/README.md.
