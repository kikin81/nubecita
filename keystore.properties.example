# Copy this file to `keystore.properties` (gitignored) and fill in the values
# for your local release keystore. Read by `app/build.gradle.kts` to configure
# the `release` signing config so `./gradlew :app:bundleRelease` produces a
# signed AAB locally.
#
# In CI, set these as env vars instead — KEYSTORE_FILE / KEYSTORE_PASSWORD /
# KEY_ALIAS / KEY_PASSWORD. The build prefers the properties file when
# present and falls back to env.
#
# `~` is expanded to $HOME so the file stays portable across machines.

storeFile=~/.android-keystores/nubecita.jks
storePassword=
keyAlias=
keyPassword=
